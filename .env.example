COORDINATOR_MODE=observe
ENFORCE_SCOPE=all
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8787

SOFT_FLOOR_MB=3072
HARD_FLOOR_MB=1536
SAFETY_OVERHEAD_MB=768

LEASE_TTL_SECONDS=300
MAX_QUEUE_DEPTH=20
MAX_QUEUE_DEPTH_HIGH=8
MAX_QUEUE_DEPTH_NORMAL=8
MAX_QUEUE_DEPTH_LOW=4

DEFAULT_DEADLINE_SECONDS=30
DEADLINE_SECONDS_HIGH=15
DEADLINE_SECONDS_NORMAL=30
DEADLINE_SECONDS_LOW=45
LOW_TIER_SHED_UNDER_SOFT_PRESSURE=true

TRIPWIRE_ENABLED=true
TRIPWIRE_WINDOW_SECONDS=60
TRIPWIRE_MAX_DENY_RATE=0.5
TRIPWIRE_MIN_SAMPLES=10

ADMIN_TOKEN=

REQUIRE_API_TOKEN=false
API_TOKEN=
ENFORCE_ALLOWLIST=false
ALLOWED_CALLERS=

LOG_LEVEL=INFO

# Staged rollout profiles
# Phase 1 — observe (safe default):
#   COORDINATOR_MODE=observe
# Phase 2 — enforce low tier only:
#   COORDINATOR_MODE=enforce
#   ENFORCE_SCOPE=low
# Phase 3 — enforce normal + low:
#   COORDINATOR_MODE=enforce
#   ENFORCE_SCOPE=normal
# Phase 4 — full enforcement:
#   COORDINATOR_MODE=enforce
#   ENFORCE_SCOPE=all